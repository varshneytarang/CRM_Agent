# Node backend
PORT=3001

# Merge
MERGE_API_KEY=replace_me
CRM_PROVIDER=merge

# Python agent
AGENT_BASE_URL=http://localhost:8000

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://crm_user:secretpass@localhost:5432/crm_agent_db
DATABASE_URL=

# Authentication
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Optional dedicated refresh token secret (falls back to JWT_SECRET)
JWT_REFRESH_SECRET=
# Access token lifetime in seconds (default 900 = 15 minutes)
JWT_ACCESS_EXPIRY_SECONDS=900
# Refresh token lifetime in seconds (default 604800 = 7 days)
JWT_REFRESH_EXPIRY_SECONDS=604800

# Token Encryption Key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Feature Flags
TOKEN_STORE_FALLBACK_MEMORY=true
# If true, backend returns deterministic analysis when Python agent is unavailable
ENABLE_LOCAL_ANALYSIS_FALLBACK=true
