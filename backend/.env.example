# Node backend
PORT=3001

# Merge
MERGE_API_KEY=replace_me
CRM_PROVIDER=merge

# Python agent
AGENT_BASE_URL=http://localhost:8000

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://crm_user:secretpass@localhost:5432/crm_agent_db
DATABASE_URL=

# Authentication
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Token Encryption Key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts all stored CRM tokens in the database
TOKEN_ENCRYPTION_KEY=

# Feature Flags
# Set to "false" to disable in-memory fallback (requires DATABASE_URL to work)
# Set to "true" to allow in-memory tokens during transition period
TOKEN_STORE_FALLBACK_MEMORY=true
