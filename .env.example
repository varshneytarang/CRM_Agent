# Node backend
PORT=3001

# Merge
MERGE_API_KEY=replace_me
CRM_PROVIDER=merge

# Python agent
AGENT_BASE_URL=http://localhost:8000
GROQ_API_KEY=
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_PERSONALIZATION_MODEL=llama-3.3-70b-versatile
SERPER_API_KEY=
APOLLO_API_KEY=
FIRECRAWL_API_KEY=
PUBLIC_SEARCH_PROVIDER=serper
ENRICHMENT_PROVIDER=apollo
EMAIL_PROVIDER=resend
OBSERVABILITY_PROVIDER=langfuse
HUMAN_APPROVAL_REQUIRED=true

# Email Sending (Resend)
RESEND_API_KEY=

# Email Provider Webhooks
# For Resend: https://resend.io/webhooks
# For SendGrid: https://sendgrid.com/docs/for-developers/tracking-events/
WEBHOOK_SECRET_RESEND=
WEBHOOK_SECRET_SENDGRID=
WEBHOOK_SECRET_MAILGUN=
WEBHOOK_SECRET_POSTMARK=

# Calendly Integration
CALENDLY_API_KEY=
CALENDLY_ORGANIZER_USERNAME=

# Redis Job Queue (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Langfuse Observability & Tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Database Configuration (PostgreSQL)
# Format: postgresql://user:password@host:port/database
# Example: postgresql://crm_user:secretpass@localhost:5432/crm_agent_db
DATABASE_URL=

# Authentication
# Generate JWT_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Optional dedicated refresh token secret (falls back to JWT_SECRET)
JWT_REFRESH_SECRET=
# Access token lifetime in seconds (default 900 = 15 minutes)
JWT_ACCESS_EXPIRY_SECONDS=900
# Refresh token lifetime in seconds (default 604800 = 7 days)
JWT_REFRESH_EXPIRY_SECONDS=604800

# Token Encryption Key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Feature Flags
TOKEN_STORE_FALLBACK_MEMORY=true
PROSPECTING_SNAPSHOT_FALLBACK_MEMORY=true
# If true, backend returns deterministic analysis when Python agent is unavailable
ENABLE_LOCAL_ANALYSIS_FALLBACK=true
# If true, queue jobs in Redis; if false or no Redis, process synchronously
USE_JOB_QUEUE=true

